<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RapidPack.MainWindow"
        Title="RapidPack – Wycena Przesyłek"
        Width="420" Height="600"
        CanResize="False">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock Text="📦 RapidPack" FontSize="24" FontWeight="Bold"/>
        <TextBlock Text="Wycena przesyłki" FontSize="14" Foreground="Gray"/>

        <Rectangle Height="1" Fill="LightGray"/>

        <TextBlock Text="Waga (kg):"/>
        <TextBox x:Name="PoleTekstoweWaga" Watermark="np. 5"/>

        <TextBlock Text="Wymiary (cm):"/>
        <Grid ColumnDefinitions="*,8,*,8,*">
            <TextBox Grid.Column="0" x:Name="PoleTekstoweWysokosc"  Watermark="Wysokość"/>
            <TextBox Grid.Column="2" x:Name="PoleTekstoweStawanosc" Watermark="Szerokość"/>
            <TextBox Grid.Column="4" x:Name="PoleTekstoweGleBokosc" Watermark="Głębokość"/>
        </Grid>

        <TextBlock Text="Typ przesyłki:"/>
        <ComboBox x:Name="ListaTypowPrzesylki" Width="200" HorizontalAlignment="Left">
            <ComboBoxItem Content="Standardowa" IsSelected="True"/>
            <ComboBoxItem Content="Ostrożnie"/>
            <ComboBoxItem Content="Paleta"/>
        </ComboBox>

        <CheckBox x:Name="CheckboxEkspres" Content="Ekspres (+15 zł)"/>

        <Rectangle Height="1" Fill="LightGray"/>

    </StackPanel>
</Window>