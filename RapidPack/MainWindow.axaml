<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RapidPack.MainWindow"
        Title="RapidPack – Wycena Przesyłek"
        Width="420" Height="600"
        CanResize="False">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock Text="📦 RapidPack" FontSize="24" FontWeight="Bold"/>
        <TextBlock Text="Wycena przesyłki" FontSize="14" Foreground="Gray"/>

        <Rectangle Height="1" Fill="LightGray"/>

    </StackPanel>
</Window>